# Local Convex deployment config — these are written by `npx convex dev`.
# Your real values live in .env.local (gitignored). You normally don't edit this by hand.
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=

# Server-side secrets are Convex DEPLOYMENT env vars, NOT entries in this file.
# Set them with the CLI (add --prod for production):
#
#   npx convex env set OPENAI_API_KEY sk-...
#   npx convex env set ORANGESLICE_API_KEY ...   # optional — live buyer verification (fail-open to a fixture)
